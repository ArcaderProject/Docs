---
const repo = 'ArcaderProject/Imager';
const releasesUrl = `https://github.com/${repo}/releases/latest`;
---

<section class="imgr" data-repo={repo} data-releases={releasesUrl}>
  <div class="imgr__head">
    <div>
      <h2 class="imgr__title">Arcader Imager herunterladen</h2>
      <p class="imgr__sub">
        Das kleine Tool lädt Arcader OS und schreibt es auf einen USB-Stick oder
        eine SD-Karte. Danach steckst du den Stick nur noch rein und bootest.
      </p>
    </div>
    <span class="imgr__ver" data-ver hidden></span>
  </div>

  <div class="imgr__pick" data-pick hidden>
    <div class="imgr__pick-label">Für dein System</div>
    <div class="imgr__pick-btns" data-pick-btns></div>
  </div>

  <a class="imgr__fallback" data-fallback href={releasesUrl} target="_blank" rel="noopener">
    Downloads werden geladen … alternativ direkt zu den Releases
  </a>

  <details class="imgr__all" data-all hidden>
    <summary>Alle Plattformen anzeigen</summary>
    <ul class="imgr__all-list" data-all-list></ul>
  </details>
</section>

<script>
  const ICON = {
    windows:
      '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M3 5.6 10.3 4.6v6.9H3zM3 12.5h7.3v6.9L3 18.4zM11.2 4.5 21 3v8.5h-9.8zM11.2 12.5H21V21l-9.8-1.4z"/></svg>',
    apple:
      '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M16.4 12.6c0-2 1.6-3 1.7-3-.9-1.4-2.4-1.5-2.9-1.6-1.2-.1-2.4.7-3 .7s-1.6-.7-2.6-.7c-1.3 0-2.6.8-3.2 2-1.4 2.4-.4 6 1 8 .7 1 1.4 2 2.5 2 1 0 1.3-.6 2.5-.6s1.5.6 2.5.6 1.8-1 2.5-2c.8-1.1 1.1-2.2 1.1-2.2s-2.1-.8-2.1-3.2zM14.6 6.3c.5-.7.9-1.6.8-2.6-.8 0-1.8.6-2.4 1.2-.5.6-1 1.5-.8 2.5.9.1 1.8-.5 2.4-1.1z"/></svg>',
    linux:
      '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2c-2 0-3 1.8-3 4 0 1.6.5 2.5.5 3.6 0 1-1.2 2-2 3.6-.8 1.5-1.6 3.2-1.6 4.6 0 1.4 1 2.1 2 2.4.3.7 1 1.2 2 1.2h4c1 0 1.7-.5 2-1.2 1-.3 2-1 2-2.4 0-1.4-.8-3.1-1.6-4.6-.8-1.6-2-2.6-2-3.6 0-1.1.5-2 .5-3.6 0-2.2-1-4-3-4z"/></svg>',
    box:
      '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2 3 6.5v11L12 22l9-4.5v-11zM12 4.2l6.5 3.3L12 10.8 5.5 7.5zM5 9.2l6 3v7.3l-6-3zM13 19.5v-7.3l6-3v7.3z"/></svg>',
  };

  function detectOs() {
    const ua = navigator.userAgent || '';
    const p = (navigator.userAgentData && navigator.userAgentData.platform) || navigator.platform || '';
    const s = (ua + ' ' + p).toLowerCase();
    if (s.includes('win')) return 'windows';
    if (s.includes('mac') || s.includes('iphone') || s.includes('ipad')) return 'macos';
    if (s.includes('linux') || s.includes('x11') || s.includes('android')) return 'linux';
    return 'other';
  }

  function classify(name) {
    const n = name.toLowerCase();
    if (n.endsWith('-setup.exe')) return { os: 'windows', key: 'win-exe', label: 'Windows', hint: 'Installer (.exe)', icon: 'windows', prio: 0 };
    if (n.endsWith('.msi')) return { os: 'windows', key: 'win-msi', label: 'Windows', hint: '.msi-Paket', icon: 'windows', prio: 1 };
    if (n.endsWith('.dmg') && n.includes('aarch64')) return { os: 'macos', key: 'mac-arm', label: 'macOS · Apple Silicon', hint: 'M1 und neuer (.dmg)', icon: 'apple', prio: 0 };
    if (n.endsWith('.dmg')) return { os: 'macos', key: 'mac-intel', label: 'macOS · Intel', hint: 'ältere Macs (.dmg)', icon: 'apple', prio: 1 };
    if (n.endsWith('.appimage')) return { os: 'linux', key: 'linux-appimage', label: 'Linux', hint: 'AppImage · läuft überall', icon: 'linux', prio: 0 };
    if (n.endsWith('.deb')) return { os: 'linux', key: 'linux-deb', label: 'Linux', hint: '.deb · Debian/Ubuntu', icon: 'box', prio: 1 };
    if (n.endsWith('.rpm')) return { os: 'linux', key: 'linux-rpm', label: 'Linux', hint: '.rpm · Fedora/openSUSE', icon: 'box', prio: 2 };
    return null;
  }

  function btn(item, primary) {
    const a = document.createElement('a');
    a.className = 'imgr__btn' + (primary ? ' imgr__btn--primary' : '');
    a.href = item.url;
    a.rel = 'noopener';
    a.innerHTML =
      `<span class="imgr__btn-icon">${ICON[item.icon] || ICON.box}</span>` +
      `<span class="imgr__btn-body"><span class="imgr__btn-label">${item.label}</span>` +
      `<span class="imgr__btn-hint">${item.hint}</span></span>`;
    return a;
  }

  async function init() {
    const root = document.querySelector('.imgr');
    if (!root) return;
    const repo = root.dataset.repo;
    const fallback = root.querySelector('[data-fallback]');

    let data;
    try {
      const res = await fetch(`https://api.github.com/repos/${repo}/releases/latest`, {
        headers: { Accept: 'application/vnd.github+json' },
      });
      if (!res.ok) throw new Error('http ' + res.status);
      data = await res.json();
    } catch (e) {
      fallback.textContent = 'Downloads konnten nicht geladen werden - hier geht es zu allen Releases';
      return;
    }

    const items = (data.assets || [])
      .map((a) => {
        const c = classify(a.name);
        return c ? { ...c, name: a.name, url: a.browser_download_url } : null;
      })
      .filter(Boolean)
      .sort((a, b) => a.prio - b.prio);

    if (!items.length) {
      fallback.textContent = 'Für dieses Release gibt es noch keine fertigen Downloads - zu den Releases';
      return;
    }

    const ver = root.querySelector('[data-ver]');
    if (data.tag_name) {
      ver.textContent = data.tag_name;
      ver.hidden = false;
    }

    const os = detectOs();
    const forOs = items.filter((i) => i.os === os);
    const pick = root.querySelector('[data-pick]');
    const pickBtns = root.querySelector('[data-pick-btns]');
    if (forOs.length) {
      forOs.slice(0, 2).forEach((i, idx) => pickBtns.appendChild(btn(i, idx === 0)));
      pick.hidden = false;
      fallback.hidden = true;
    }

    const all = root.querySelector('[data-all]');
    const list = root.querySelector('[data-all-list]');
    items.forEach((i) => {
      const li = document.createElement('li');
      const a = btn(i, false);
      li.appendChild(a);
      list.appendChild(li);
    });
    all.hidden = false;
    if (forOs.length) all.querySelector('summary').textContent = 'Andere Plattformen anzeigen';
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style is:global>
  .imgr [hidden] {
    display: none !important;
  }
  .imgr {
    border: 2px solid var(--sl-color-hairline-shade, var(--sl-color-gray-5));
    background: var(--sl-color-bg-nav);
    padding: 1.25rem 1.4rem 1.4rem;
    margin-top: 1rem;
  }
  .imgr__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .imgr__title {
    font-size: 1.15rem;
    margin: 0;
  }
  .imgr__sub {
    margin: 0.4rem 0 0;
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
    max-width: 46ch;
  }
  .imgr__ver {
    font-family: var(--arcader-font-retro);
    font-size: 0.7rem;
    color: #fff;
    background: var(--sl-color-accent);
    padding: 0.25rem 0.5rem;
    white-space: nowrap;
  }
  .imgr__pick {
    margin-top: 1.1rem;
  }
  .imgr__pick-label {
    font-family: var(--arcader-font-retro);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.5rem;
  }
  .imgr__pick-btns {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .imgr__btn {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.7rem 0.95rem;
    border: 2px solid var(--sl-color-hairline-shade, var(--sl-color-gray-5));
    background: var(--sl-color-bg);
    color: var(--sl-color-white);
    text-decoration: none;
    min-width: 0;
    transition: border-color 0.15s, transform 0.05s;
  }
  .imgr__btn:hover {
    border-color: var(--sl-color-accent);
    text-shadow: none;
  }
  .imgr__btn:active {
    transform: translateY(1px);
  }
  .imgr__btn--primary {
    background: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
    color: #fff;
  }
  .imgr__btn--primary:hover {
    filter: brightness(1.08);
    border-color: var(--sl-color-accent);
  }
  .imgr__btn-icon {
    display: flex;
    flex: 0 0 auto;
  }
  .imgr__btn-body {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
  }
  .imgr__btn-label {
    font-weight: 600;
    font-size: 0.92rem;
  }
  .imgr__btn-hint {
    font-size: 0.74rem;
    opacity: 0.8;
  }
  .imgr__fallback {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.85rem;
  }
  .imgr__all {
    margin-top: 1.1rem;
  }
  .imgr__all > summary {
    cursor: pointer;
    font-family: var(--arcader-font-retro);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--sl-color-gray-3);
  }
  .imgr__all-list {
    list-style: none;
    padding: 0;
    margin: 0.8rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.6rem;
  }
  .imgr__all-list li {
    margin: 0;
  }
  .imgr__all-list .imgr__btn {
    width: 100%;
  }
</style>
